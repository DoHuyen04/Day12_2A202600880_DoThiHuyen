# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=KnowledgeBase RAG Agent
APP_VERSION=1.0.0

# RAG
DATA_DIR=data
TOP_K=3
CHUNK_MAX_CHARS=700
EMBEDDING_PROVIDER=mock        # mock | local | openai

# LLM (để trống = dùng mock LLM, offline, miễn phí)
OPENAI_API_KEY=
LLM_MODEL=mock-rag-llm

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0

# CORS
ALLOWED_ORIGINS=*
